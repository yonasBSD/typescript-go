//// [tests/cases/compiler/thisPropertyAssignmentTyping.ts] ////

=== main.js ===
class C1 {
>C1 : C1

    constructor() {
        this.foo = [3];
>this.foo = [3] : number[]
>this.foo : any
>this : this
>foo : any
>[3] : number[]
>3 : 3

        this.foo = [this.foo[0] * 2];
>this.foo = [this.foo[0] * 2] : number[]
>this.foo : any
>this : this
>foo : any
>[this.foo[0] * 2] : number[]
>this.foo[0] * 2 : number
>this.foo[0] : number
>this.foo : number[]
>this : this
>foo : number[]
>0 : 0
>2 : 2

        this.foo;  // number[]
>this.foo : number[]
>this : this
>foo : number[]
    }
}

